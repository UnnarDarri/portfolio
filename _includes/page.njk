---
title: Page template
---
<!DOCTYPE html>
<html lang="is">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
  <title>{{ title }} | Unnar Darri</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>

<body>

  <!-- HEADER -->
  <header class="nav">

    <a class="logo" href="/">Unnar Darri</a>

    <nav class="menu">
      <a class="{{ 'active' if '/cinematography' in page.url }}" href="/cinematography">Cinematography</a>
      <a class="{{ 'active' if '/photography' in page.url }}" href="/photography">Photography</a>
      <a class="{{ 'active' if '/about' in page.url }}" href="/about">About me</a>
    </nav>

  </header>

  {{ content | safe }}

  <!-- FOOTER -->
  <footer class="footer">
    <small class="copyright">&copy; 2026 Unnar Darri</small>

    <div class="footer-contact">
      <a href="mailto:unnar@unnardarri.com">Email</a>
      <a href="tel:+3540000000">Phone</a>
      <a href="https://instagram.com/unnar_darri">Instagram</a>
      <a href="https://youtube.com/@studiokria">YouTube</a>
    </div>

  </footer>
</body>
</html>
