---
layout: page.njk
title: Single movie
meta: Movie meta
description: Movie description
---
<main class="project-page">
  <h1 class="project-title">{{ title }}</h1>
  <p class="project-meta">{{ meta }}</p>
  <p class="project-desc">{{ description }}</p>

  <div class="video">
    <iframe width="100%" src="https://www.youtube.com/embed/{{ youtube_id }}"></iframe>
  </div>

  {%- for src in images -%}
    <img src="{{ src }}">
  {%- endfor -%}
</main>
